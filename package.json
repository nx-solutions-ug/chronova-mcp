{
  "name": "@chronova/mcp-server",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "chronova-mcp": "./dist/index.js",
    "chronova-mcp-stdio": "./dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
